---
const { pathname } = Astro.url;
const pathSegments = pathname.split('/').filter(Boolean);

const breadcrumbs = pathSegments.map((segment, index) => {
  const href = '/' + pathSegments.slice(0, index + 1).join('/');
  const label = segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' ');
  return { label, href };
});
---

{breadcrumbs.length > 0 && (
  <nav class="max-w-7xl mx-auto px-5 py-4 mb-4 flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-muted/60" aria-label="Breadcrumb">
    <a href="/" class="hover:text-teal transition-colors">Home</a>
    {breadcrumbs.map((crumb, index) => (
      <div class="flex items-center gap-2">
        <span>/</span>
        {index === breadcrumbs.length - 1 ? (
          <span class="text-teal font-medium">{crumb.label}</span>
        ) : (
          <a href={crumb.href} class="hover:text-teal transition-colors">{crumb.label}</a>
        )}
      </div>
    ))}
  </nav>
)}

