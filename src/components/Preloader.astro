---
// src/components/Preloader.astro
---
<div id="preloader" class="fixed inset-0 z-[100] bg-charcoal flex flex-col items-center justify-center transition-opacity duration-500">
  <div class="relative flex flex-col items-center">
    <div class="font-poppins text-6xl font-black text-offwhite tracking-tighter opacity-0" id="preloader-logo">
      A<span class="text-teal">.</span>
    </div>
    <div class="mt-6 w-48 h-px bg-charcoal-light relative overflow-hidden">
      <div id="preloader-bar" class="absolute top-0 left-0 h-full bg-teal w-0"></div>
    </div>
    <div class="mt-4 font-mono text-[10px] text-muted tracking-[0.2em] uppercase opacity-0" id="preloader-text">
      Initializing System
    </div>
  </div>
</div>

<script>
  import { gsap } from "gsap";

  function initPreloader() {
    const preloader = document.getElementById("preloader");
    if (!preloader) return;

    // Check if we already loaded in this session to avoid annoying users
    const hasLoaded = sessionStorage.getItem("site_loaded");
    
    // If it's a ViewTransition navigation, we don't want the full long preloader
    // Just a quick fade if desired, or skip it.
    if (hasLoaded) {
      preloader.style.display = "none";
      return;
    }

    // First time load animation
    document.body.style.overflow = "hidden"; // Prevent scrolling while loading

    const tl = gsap.timeline({
      onComplete: () => {
        sessionStorage.setItem("site_loaded", "true");
        gsap.to(preloader, {
          opacity: 0,
          duration: 0.8,
          ease: "power2.inOut",
          onComplete: () => {
            preloader.style.display = "none";
            document.body.style.overflow = ""; // Restore scrolling
          }
        });
      }
    });

    tl.to("#preloader-logo", { opacity: 1, y: -10, duration: 0.8, ease: "power3.out" })
      .to("#preloader-text", { opacity: 1, duration: 0.4 }, "-=0.4")
      .to("#preloader-bar", { width: "100%", duration: 1.5, ease: "slow(0.7, 0.7, false)" }, "-=0.2");
  }

  // Run on initial load
  initPreloader();

  // Handle astro:page-load (ViewTransitions) - we skip the long loader but could add a micro-loader here
  document.addEventListener("astro:page-load", () => {
    const preloader = document.getElementById("preloader");
    if (preloader) {
       preloader.style.display = "none";
    }
  });
</script>
