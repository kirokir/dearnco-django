---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import AdminInterface from "../components/AdminInterface";

const adminPassword = "local"; // Hardcoded default key
let isAuthenticated = Astro.cookies.has("admin_session");
let error = "";

if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const password = data.get("password");
  
  if (password === adminPassword) {
    Astro.cookies.set("admin_session", "true", { path: "/", httpOnly: true, secure: true, maxAge: 60 * 60 * 24 });
    isAuthenticated = true;
  } else {
    error = "Invalid connection key.";
  }
}
---

<Layout title="Admin Panel — Arjun Jayesh">
  <section class="section-padding mt-16 max-w-6xl mx-auto">
    <div class="mb-12">
      <h1 class="font-inter text-4xl font-bold text-offwhite mb-4 uppercase tracking-[0.2em]">
        <span class="text-teal">/</span> Command Center
      </h1>
      <p class="font-lora text-muted max-w-2xl">
        Manage site settings, blog content, and system parameters from a secure administrative interface.
      </p>
    </div>

    {isAuthenticated ? (
      <Fragment>
        <!-- Interface -->
        <div class="min-h-[600px]">
          <AdminInterface client:only="preact" />
        </div>
        
        <!-- Footer/Admin Info -->
        <div class="mt-12 p-6 border border-teal/10 rounded bg-teal/5 flex items-center justify-between">
          <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-teal animate-pulse"></div>
            <span class="font-mono text-[10px] text-teal uppercase tracking-widest">System Online — Secure Connection Verified</span>
          </div>
          <span class="font-mono text-[10px] text-muted">A_JAYESH v4.0.2</span>
        </div>
      </Fragment>
    ) : (
      <div class="max-w-md mx-auto mt-20 p-8 bg-charcoal-light/10 border border-charcoal-light/30 rounded-xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-teal to-transparent"></div>
        <h2 class="font-inter text-2xl font-semibold text-offwhite mb-6 text-center">Authentication Required</h2>
        
        {error && (
          <div class="mb-6 p-3 bg-red-500/10 border border-red-500/30 text-red-400 font-mono text-xs rounded text-center">
            {error}
          </div>
        )}

        <form method="POST" data-astro-reload class="flex flex-col gap-4">
          <div>
            <label for="password" class="block font-mono text-xs text-muted mb-2 uppercase tracking-widest">Master Key</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              class="w-full bg-charcoal-dark border border-charcoal-light/50 rounded p-3 text-offwhite font-mono focus:outline-none focus:border-teal transition-colors"
              placeholder="••••••••"
              required
            />
          </div>
          <button type="submit" class="mt-4 w-full py-3 bg-teal/10 border border-teal/30 hover:bg-teal hover:text-charcoal text-teal font-mono tracking-widest uppercase transition-all duration-300 rounded font-bold">
            [ Establish Connection ]
          </button>
        </form>
      </div>
    )}
  </section>
</Layout>

