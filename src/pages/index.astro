---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";

let ssrError = null;
try {
  // We'll let the components render normally
} catch (e: any) {
  ssrError = {
    message: e.message,
    stack: e.stack
  };
}
---

{ssrError ? (
  <div style="padding: 2rem; background: #1a1a1a; color: #ff5555; font-family: monospace;">
    <h1>SSR CRASH DETECTED</h1>
    <p><strong>Message:</strong> {ssrError.message}</p>
    <pre style="background: #000; padding: 1rem; overflow: auto; max-height: 50vh;">{ssrError.stack}</pre>
  </div>
) : (
  <Layout>
    <Hero />
  </Layout>
)}
