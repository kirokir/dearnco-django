---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";
import LeadFunnel from "../components/LeadFunnel";

let enterpriseAssets = {
    hero_video_url: "https://assets.mixkit.co/videos/preview/mixkit-digital-animation-of-a-circuit-board-1113-large.mp4",
    logo_url: "",
    locations: "INDIA | CHINA | GCC",
    company_name: "KINBO TECHNOLOGIES PRIVATE LIMITED"
};

if (supabase) {
    try {
        const { data, error } = await supabase
            .from('site_config')
            .select('data')
            .eq('key', 'enterprise_assets')
            .single();
        
        if (error && error.code !== 'PGRST116') {
            console.error('Homepage Data Fetch Error:', error);
        } else if (data?.data) {
            enterpriseAssets = { ...enterpriseAssets, ...data.data };
        }
    } catch (e) {
        console.error('Homepage SSR Crash Caught:', e);
    }

    // Fetch Works/Portfolio
    const { data: worksData, error: worksError } = await supabase
        .from('works')
        .select('*')
        .order('sort_order', { ascending: true });
    
    if (worksError) console.error('Works Fetch Error:', worksError);
    var works = worksData || [];
} else {
    console.warn('Supabase client not available on homepage SSR');
    var works = [];
}
---

<Layout title="Home" description="KINBO TECHNOLOGIES PRIVATE LIMITED builds intelligent everyday applications that combine practical technology with user-focused design.">
  
  <!-- Startup Animation Overlay -->
  <div id="startup-overlay" class="fixed inset-0 z-[100] bg-charcoal hidden flex-col items-center justify-center overflow-hidden">
    <div class="relative">
      <div id="startup-logo" class="w-24 h-24 bg-teal/10 rounded-2xl border border-teal/20 flex items-center justify-center mb-8 scale-0 overflow-hidden">
        {enterpriseAssets.logo_url ? (
          <img src={enterpriseAssets.logo_url} alt="Logo" class="w-full h-full object-cover" />
        ) : (
          <span class="text-teal font-inter text-4xl font-bold">K</span>
        )}
      </div>
      <div id="startup-bar" class="absolute -bottom-4 left-0 w-0 h-px bg-teal shadow-[0_0_10px_rgba(42,157,143,0.8)]"></div>
    </div>
    <div id="startup-text" class="font-mono text-[10px] text-teal uppercase tracking-[0.5em] opacity-0 translate-y-4">
      Initializing Kinbo Systems
    </div>
  </div>

  <!-- Hero Section with Video Parallax -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden" id="hero">
    <!-- Parallax Background Container -->
    <div class="absolute inset-0 z-0 scale-110" id="hero-video-container"
         data-parallax={enterpriseAssets.hero_parallax_intensity ?? 20}>
      <div class="absolute inset-0 bg-[#0A0F1C] z-10 pointer-events-none"
           style={`opacity: ${enterpriseAssets.hero_bg_darkness ?? 0.8};`}></div>
      {(enterpriseAssets.hero_bg_type === 'video' || !enterpriseAssets.hero_bg_type) ? (
        <video 
          autoplay 
          muted 
          loop 
          playsinline 
          class="w-full h-full object-cover"
          style={`filter: blur(${enterpriseAssets.hero_bg_blur ?? 2}px); opacity: ${enterpriseAssets.hero_bg_opacity ?? 0.4};`}
        >
          <source src={enterpriseAssets.hero_video_url} type="video/mp4" />
        </video>
      ) : (
        <img 
          src={enterpriseAssets.hero_video_url}
          alt="Hero Background"
          class="w-full h-full object-cover"
          style={`filter: blur(${enterpriseAssets.hero_bg_blur ?? 2}px); opacity: ${enterpriseAssets.hero_bg_opacity ?? 0.4};`}
        />
      )}
    </div>

    <div class="relative z-20 max-w-5xl mx-auto px-6 text-center">
      <span class="font-mono text-[10px] text-teal uppercase tracking-[0.6em] block mb-6 hero-anim opacity-0 translate-y-8">
        ELITE SOFTWARE ENGINEERING ARCHITECTS
      </span>
      <h1 class="font-inter text-4xl sm:text-5xl md:text-8xl font-extrabold text-offwhite leading-[1.1] mb-8 hero-anim opacity-0 translate-y-8 tracking-tight">
        We Engineer Scalable <span class="text-teal">Software</span><br/>
        That Drives <span class="text-teal">Market Dominance.</span>
      </h1>
      <p class="font-inter text-base sm:text-lg text-muted max-w-2xl mx-auto leading-relaxed mb-12 hero-anim opacity-0 translate-y-8 px-4 font-light">
        We bypass complexity to deliver high-performance digital infrastructure. High-ticket engineering for firms that command authority.
      </p>
      <div class="flex flex-col items-center gap-6 hero-anim opacity-0 translate-y-8">
        <div class="flex flex-wrap gap-4 justify-center">
          <a href="#audit" class="px-10 py-4 bg-emerald text-charcoal-dark font-inter font-bold uppercase tracking-widest text-[11px] rounded-full hover:shadow-[0_0_40px_rgba(16,185,129,0.4)] hover:scale-105 transition-all duration-300">
            Claim Your Technical Feasibility Audit
