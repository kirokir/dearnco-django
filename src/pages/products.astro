---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";

let dynamicProducts: any[] = [];
if (supabase) {
  try {
    const { data, error } = await supabase
      .from("products")
      .select("*")
      .eq("status", "active")
      .order("sort_order", { ascending: true });
    
    if (error) {
      console.error("Products Supabase Fetch Error:", error);
    } else if (data) {
      dynamicProducts = data;
    }
  } catch (e) {
    console.error("Products SSR Crash Caught:", e);
  }
} else {
  console.warn("Supabase client not available on Products SSR");
}

import Breadcrumbs from "../components/Breadcrumbs.astro";
import AutoCarousel from "../components/AutoCarousel";
---

<Layout title="Products" description="Explore KINBO TECHNOLOGIES PRIVATE LIMITED's product ecosystem: Glowup for skin health insights and Relic for creator-focused marketplace.">
  <section class="max-w-7xl mx-auto pt-24 px-6">
    <Breadcrumbs />
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="font-mono text-xs text-teal uppercase tracking-[0.3em] block mb-3">Products</span>
      <h1 class="font-poppins text-3xl sm:text-4xl md:text-5xl font-bold text-offwhite mb-4">
        A connected <span class="text-teal">ecosystem</span>
      </h1>
      <p class="font-lora text-muted max-w-2xl mx-auto leading-relaxed">
        KINBO currently focuses on two integrated products that form a connected system. Insights generated in one application guide actions in another — from understanding to action, transparently.
      </p>
      <div class="mt-6 mx-auto w-16 h-px bg-gradient-to-r from-transparent via-teal to-transparent"></div>
    </div>

    <!-- GLOWUP -->
    <div id="glowup" class="mb-20 product-block" style="opacity:0; transform:translateY(30px);">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14 rounded-2xl bg-teal/10 flex items-center justify-center">
          <svg class="w-7 h-7 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <h2 class="font-poppins text-2xl sm:text-3xl font-bold text-offwhite">Glowup</h2>
          <span class="font-mono text-[10px] text-teal uppercase tracking-widest">Skin Health Intelligence</span>
        </div>
      </div>

      <p class="font-lora text-muted leading-relaxed mb-8 max-w-3xl">
        Glowup is a consumer application that helps users understand and track visible skin health indicators using image analysis and structured reporting. It provides practical, non-medical insights to support personal skin care decisions.
      </p>

      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Skin Assessment</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Users capture facial images and the system analyzes visible patterns to identify possible skin condition indicators.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Condition Scoring</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">The application generates structured reports showing relative severity levels of different skin conditions.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Insight Dashboard</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Users receive explanations of what each condition indicator represents and how lifestyle habits may influence them.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Progress Tracking</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Users repeat scans over time and view changes through a progress dashboard showing trends and comparisons.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5 sm:col-span-2">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Lifestyle Suggestions</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">The application provides practical non-medical suggestions to help improve skin health over time, such as hydration reminders, sleep quality factors, and environmental considerations.</p>
        </div>
      </div>

      <div class="mb-12">
        <span class="font-mono text-[9px] text-muted/60 uppercase tracking-widest block mb-4">Product Interface</span>
        <AutoCarousel client:load items={[
            "https://images.unsplash.com/photo-1512941937669-90a1358b335c?auto=format&fit=crop&w=400&h=800",
            "https://images.unsplash.com/photo-1523206489230-c012c6422b1f?auto=format&fit=crop&w=400&h=800",
            "https://images.unsplash.com/photo-1551650975-87deedd944c3?auto=format&fit=crop&w=400&h=800"
        ]} />
      </div>

      <div class="p-4 rounded-xl border border-yellow-500/20 bg-yellow-500/5 mb-20">
        <p class="font-mono text-[10px] text-yellow-400 uppercase tracking-wider">
          ⚠ Disclaimer: Glowup does not provide medical diagnosis and is intended only for informational and personal tracking purposes. Always consult a qualified healthcare professional for medical advice.
        </p>
      </div>
    </div>

    <!-- RELIC -->
    <div id="relic" class="mb-20 product-block" style="opacity:0; transform:translateY(30px);">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-14 h-14 rounded-2xl bg-teal/10 flex items-center justify-center">
          <svg class="w-7 h-7 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
        </div>
        <div>
          <h2 class="font-poppins text-2xl sm:text-3xl font-bold text-offwhite">Relic</h2>
          <span class="font-mono text-[10px] text-teal uppercase tracking-widest">Creator Marketplace</span>
        </div>
      </div>

      <p class="font-lora text-muted leading-relaxed mb-8 max-w-3xl">
        Relic is a digital multivendor marketplace that allows creators, students, and independent sellers to open online stores easily. It removes the technical barriers to e-commerce so sellers can focus on what they do best.
      </p>

      <div class="grid sm:grid-cols-2 gap-4">
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Seller Onboarding</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Sellers can register and begin offering products with minimal setup. No technical knowledge required.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Personalized Stores</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Each seller can maintain their own store page and organize their products for customers.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Customer Experience</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Buyers can follow stores they trust and discover products through recommendations and community signals.</p>
        </div>
        <div class="p-5 rounded-xl border border-charcoal-light/20 bg-charcoal-light/5">
          <h4 class="font-poppins text-sm font-bold text-offwhite mb-2">Cross-Platform Sync</h4>
          <p class="font-lora text-xs text-muted leading-relaxed">Purchases and account data can be synchronized across devices for consistent user experience.</p>
        </div>
      </div>

      <div class="mb-20">
        <span class="font-mono text-[9px] text-muted/60 uppercase tracking-widest block mb-4">Relic Experience</span>
        <AutoCarousel client:load items={[
            "https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=400&h=800",
            "https://images.unsplash.com/photo-1472851294608-062f824d29cc?auto=format&fit=crop&w=400&h=800",
            "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=400&h=800"
        ]} />
      </div>
    </div>

    <!-- Integration -->
    <div class="mb-20 p-8 rounded-2xl border border-teal/20 bg-teal/5 product-block" style="opacity:0; transform:translateY(30px);">
      <h2 class="font-poppins text-xl font-bold text-offwhite mb-4">How They Connect</h2>
      <div class="font-lora text-muted leading-relaxed space-y-3">
        <p>Glowup identifies user skin concerns and suggests categories of products that may help address them. Relic provides a marketplace where users can discover relevant products offered by independent sellers.</p>
        <p>This connection allows users to move from insight to action in a transparent way. Users remain in full control of their decisions and product selection — the system informs, it does not prescribe.</p>
      </div>
    </div>

    <!-- Dynamic Products from Admin -->
    {dynamicProducts.length > 0 && (
      <div class="mb-16">
        <div class="text-center mb-12">
          <span class="font-mono text-xs text-teal uppercase tracking-[0.3em] block mb-3">More Products</span>
          <h2 class="font-poppins text-2xl font-bold text-offwhite">Expanding the Ecosystem</h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-8">
          {dynamicProducts.map((prod) => (
            <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 product-block" style="opacity:0; transform:translateY(20px);">
              <div class="flex items-center gap-4 mb-4">
                {prod.logo_url ? (
                    <img src={prod.logo_url} alt={prod.name} class="w-12 h-12 rounded-lg object-contain bg-charcoal-dark/50 p-2" />
                ) : (
                    <div class="w-12 h-12 rounded-lg bg-teal/10 flex items-center justify-center">
                        <span class="text-teal font-bold">{prod.name.charAt(0)}</span>
                    </div>
                )}
                <div>
                   <h3 class="font-poppins text-xl font-bold text-offwhite">{prod.name}</h3>
                   {prod.tagline && <span class="font-mono text-[10px] text-teal uppercase tracking-widest">{prod.tagline}</span>}
                </div>
              </div>
              <p class="font-lora text-sm text-muted leading-relaxed mb-6">{prod.description}</p>
              
              {prod.screenshots && prod.screenshots.length > 0 && (
                <div class="pt-4 pointer-events-none grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all">
                    <AutoCarousel client:load items={prod.screenshots} speed={30} />
                </div>
              )}

              <div class="flex gap-4 mt-8">
                 {prod.play_store_link && <span class="text-[9px] font-mono text-muted uppercase">Play Store</span>}
                 {prod.app_store_link && <span class="text-[9px] font-mono text-muted uppercase">App Store</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- MODELS SECTION -->
    <div id="models" class="mb-20 product-block" style="opacity:0; transform:translateY(30px);">
      <div class="text-center mb-16">
        <span class="font-mono text-xs text-teal uppercase tracking-[0.3em] block mb-3">Industry Standard Models</span>
        <h2 class="font-poppins text-3xl sm:text-4xl font-bold text-offwhite mb-4">
          Framework <span class="text-teal">Library</span>
        </h2>
        <p class="font-lora text-muted max-w-2xl mx-auto leading-relaxed">
          Standardized architectural models and business frameworks designed to solve specific operational challenges across Indian industry verticals.
        </p>
      </div>

      <!-- Feature Collage -->
      <div class="mb-16 rounded-3xl overflow-hidden border border-charcoal-light/20 relative group">
          <div class="absolute inset-0 bg-gradient-to-t from-charcoal via-transparent to-transparent z-10"></div>
          <img 
            src="/indian_business_models_collage_1776926783752.png" 
            alt="Business Ecosystem" 
            class="w-full h-80 object-cover opacity-60 group-hover:scale-105 transition-transform duration-1000 grayscale hover:grayscale-0"
          />
          <div class="absolute bottom-8 left-8 z-20">
              <span class="font-mono text-[10px] text-teal uppercase tracking-widest block mb-2">Integrated Verticals</span>
              <h3 class="font-poppins text-2xl font-bold text-offwhite">Scaling the Indian Enterprise</h3>
          </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- WordPress Sites -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6 border border-teal/20">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          </div>
          <h3 class="font-poppins text-xl font-bold text-offwhite mb-3">WordPress Sites</h3>
          <p class="font-lora text-sm text-muted leading-relaxed">Agile CMS frameworks for high-velocity deployments, featuring SEO tuning and automated performance optimization.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="text-[9px] font-mono text-teal uppercase border border-teal/20 px-2 py-0.5 rounded">Elementor-Pro</span>
            <span class="text-[9px] font-mono text-teal uppercase border border-teal/20 px-2 py-0.5 rounded">WooCommerce-API</span>
          </div>
        </div>

        <!-- Jewellery Retail -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6 border border-teal/20">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/></svg>
          </div>
          <h3 class="font-poppins text-xl font-bold text-offwhite mb-3">Jewellery Retails</h3>
          <p class="font-lora text-sm text-muted leading-relaxed">High-asset value inventory management including vault-sync, SKU tracking, and secure payment orchestration.</p>
          <span class="mt-4 inline-block text-[9px] font-mono text-muted uppercase tracking-widest">Example: CaratLane Model</span>
        </div>

        <!-- Clothing & Fashion -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6 border border-teal/20">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3 class="font-poppins text-xl font-bold text-offwhite mb-3">Clothing Brands</h3>
          <p class="font-lora text-sm text-muted leading-relaxed">Visual-centric D2C platforms optimized for high mobile conversion and rapid style iteration cycles.</p>
          <span class="mt-4 inline-block text-[9px] font-mono text-muted uppercase tracking-widest">Example: Myntra/D2C Ecosystem</span>
        </div>

        <!-- Banking & Fintech -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6 border border-teal/20">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
          </div>
          <h3 class="font-poppins text-xl font-bold text-offwhite mb-3">Banks & Fintech</h3>
          <p class="font-lora text-sm text-muted leading-relaxed">Financial architectures emphasizing security, KYC/AML automation, and low-latency transaction nodes.</p>
          <div class="mt-4 flex gap-2">
            <span class="text-[8px] font-mono bg-charcoal-dark/50 px-2 py-1 rounded">UPI Integration</span>
            <span class="text-[8px] font-mono bg-charcoal-dark/50 px-2 py-1 rounded">RBAC-Security</span>
          </div>
        </div>

        <!-- Boutiques & High-End Retail -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6 border border-teal/20">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
          </div>
          <h3 class="font-poppins text-xl font-bold text-offwhite mb-3">Luxury Boutiques</h3>
          <p class="font-lora text-sm text-muted leading-relaxed">Exclusive digital experiences for luxury goods, focusing on storytelling and elite customer journey mapping.</p>
          <span class="mt-4 inline-block text-[9px] font-mono text-muted uppercase tracking-widest">Example: Sabyasachi Model</span>
        </div>

        <!-- Supermarkets & Q-Commerce -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300">
          <div class="w-12 h-12 bg-teal/10 rounded-xl flex items-center justify-center mb-6 border border-teal/20">
            <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="font-poppins text-xl font-bold text-offwhite mb-3">Supermarkets</h3>
          <p class="font-lora text-sm text-muted leading-relaxed">Integrated supply chain solutions with real-time stock-tracking and hyperlocal delivery orchestration.</p>
          <span class="mt-4 inline-block text-[9px] font-mono text-muted uppercase tracking-widest">Example: Zepto/BigBasket Infra</span>
        </div>

        <!-- Engineering & Heavy Industry -->
        <div class="p-8 rounded-3xl border border-charcoal-light/10 bg-charcoal-light/5 hover:border-teal/30 hover:bg-teal/[0.02] transition-all duration-300 lg:col-span-3">
            <div class="flex flex-col md:flex-row items-center gap-8">
                <div class="w-16 h-16 bg-teal/10 rounded-2xl flex items-center justify-center border border-teal/20 shrink-0">
                    <svg class="w-8 h-8 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.638.319a4 4 0 01-1.833.433H6.5V10h.5a2 2 0 001.507-.68l.024-.03a2 2 0 011.502-.68H11l.245-1.225A2 2 0 0113.205 6h.79a2 2 0 011.96 1.605L16.5 10H19m0 10v-3.5a1 1 0 011-1h.5a.5.5 0 000-1H19a1 1 0 01-1-1v-4a1 1 0 011-1h.5a.5.5 0 000-1H19a1 1 0 01-1-1V5a1 1 0 011-1h1a1 1 0 000-2H17.5a2.5 2.5 0 00-2.5 2.5V5a1 1 0 01-1 1h-1.111c-1.249 0-2.43.513-3.268 1.411L8.5 8.5V10H7v8.5a1.5 1.5 0 003 0V17h2.333c1.47 0 2.873-.615 3.861-1.691l1.234-1.345a1 1 0 011.507.03z"/></svg>
                </div>
                <div class="flex-1">
                    <h3 class="font-poppins text-xl font-bold text-offwhite mb-2">Engineering & Heavy Industry Firms</h3>
                    <p class="font-lora text-sm text-muted leading-relaxed mb-4">Enterprise-grade systems for industrial asset management, project tracking, and complex bill-of-materials (BOM) orchestration. Designed for the scale of Tata Projects and L&T systems.</p>
                    <div class="flex gap-4">
                        <span class="text-[9px] font-mono text-teal border-b border-teal/20 pb-0.5">Asset-Lifecycle-Mgmt</span>
                        <span class="text-[9px] font-mono text-teal border-b border-teal/20 pb-0.5">Supply-Chain-Transparency</span>
                        <span class="text-[9px] font-mono text-teal border-b border-teal/20 pb-0.5">Industrial-IoT-Ready</span>
                    </div>
                </div>
            </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.utils.toArray(".product-block").forEach((el: any) => {
    gsap.to(el, {
      scrollTrigger: { trigger: el, start: "top 85%" },
      opacity: 1, y: 0, duration: 0.7, ease: "power2.out"
    });
  });
</script>
